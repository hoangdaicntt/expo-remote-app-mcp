{
  "name": "expo-remote-app-workspace",
  "version": "1.0.1",
  "private": true,
  "description": "Workspace for Expo Remote App MCP server and Expo bridge packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w expo-remote-app-mcp",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start -w expo-remote-app-mcp",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
